# ── Polymarket ────────────────────────────────────────────────────────────────
# Generate these with: python scripts/generate_api_keys.py
POLY_PRIVATE_KEY=0xyour_polygon_wallet_private_key_here
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_API_PASSPHRASE=your_polymarket_api_passphrase

# ── BTC Price Feed ────────────────────────────────────────────────────────────
# Binance public WebSocket — no key required
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading Mode ──────────────────────────────────────────────────────────────
# watch  → log signals only, no orders (start here)
# paper  → simulate orders, track PnL (validate before going live)
# live   → real CLOB orders on Polygon (use after paper validation)
TRADING_MODE=watch

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/poly_edge.db
